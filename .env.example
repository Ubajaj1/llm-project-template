# LLM Providers — add the ones you use, leave the rest blank
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Model defaults — override per-call via router.py
DEFAULT_MODEL=claude-opus-4-6
FALLBACK_MODEL=gpt-4o

# RAG / Vector Store
VECTOR_STORE=chroma                  # chroma | pinecone | weaviate | pgvector
PINECONE_API_KEY=
PINECONE_INDEX=
CHROMA_PERSIST_DIR=./data/processed/chroma

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100

# Observability
TRACING_ENABLED=true
LANGFUSE_PUBLIC_KEY=                 # or use LANGSMITH_API_KEY
LANGFUSE_SECRET_KEY=
LANGSMITH_API_KEY=

# Cost limits (USD)
MAX_COST_PER_CALL=0.10
MAX_COST_PER_USER_DAY=1.00

# Evals
EVAL_THRESHOLD_FAITHFULNESS=0.85
EVAL_THRESHOLD_RELEVANCY=0.80
EVAL_FAIL_CI=true                    # set false to warn-only in CI

# Audit logging
AUDIT_ENABLED=true
AUDIT_LOG_PATH=./data/audit/audit.jsonl
AUDIT_STORE_RAW_PROMPTS=false        # set true only for debugging — stores full prompts

# Semantic cache
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_SIMILARITY_THRESHOLD=0.95     # cosine similarity threshold for cache hit
CACHE_MAX_SIZE=1000                  # max cached query-response pairs (LRU eviction)
ANTHROPIC_PROMPT_CACHE=true         # enable Anthropic prompt prefix caching

# Guardrails
GUARDRAILS_INPUT_POLICY=block        # block | warn | log_only
GUARDRAILS_OUTPUT_POLICY=warn        # block | warn | log_only
GUARDRAILS_MAX_INPUT_TOKENS=8000

# Rate limiting
RATE_LIMIT_RPM=60                    # requests per minute per user
RATE_LIMIT_TPM=100000                # tokens per minute per user
